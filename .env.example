# Azure GenAI Lab MaaS — Primary LLM
AZURE_OPENAI_API_KEY=your_azure_genailab_api_key_here
AZURE_OPENAI_ENDPOINT=https://your-genailab-endpoint.openai.azure.com
AZURE_OPENAI_API_VERSION=2024-02-01

# Primary model (Azure)
LLM_MODEL=azure/genailab-maas-gpt-4o

# Fallback model (Ollama local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=llama3.2:3b-instruct-q4_K_M
OLLAMA_EMBED_MODEL=gte-large

# Reasoning model (Azure DeepSeek — used for complex validation only)
REASONING_MODEL=azure_ai/genailab-maas-DeepSeek-R1

# App config
USE_AZURE=true
# Set USE_AZURE=false to force all calls through Ollama (offline mode)
